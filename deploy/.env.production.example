# Copy to project root as .env before deploying:
# cp deploy/.env.production.example .env

# === VPS IP + port 3007 ===
# VPS IP configured for port 3007
APP_DOMAIN=163.47.151.250
APP_PORT=3007
APP_URL=http://163.47.151.250:3007

# === WHEN YOU GET A DOMAIN LATER ===
# APP_DOMAIN=eventbooking.com
# APP_PORT=80
# APP_URL=https://eventbooking.com

# Strong random secrets — generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_GENERATE=replace-with-another-long-random-secret

# Required once to create the first admin account
ADMIN_BOOTSTRAP_SECRET=replace-with-bootstrap-secret

# Email (for ticket/booking notifications)
EMAIL=
PASSWORD=

# Google / Firebase (optional — for Google sign-in in production)
FIREBASE_PROJECT_ID=
GOOGLE_CLIENT_ID=
VITE_PUBLIC_FIREBASE_API_KEY=
VITE_PUBLIC_FIREBASE_AUTH_DOMAIN=
VITE_PUBLIC_FIREBASE_PROJECT_ID=
VITE_PUBLIC_FIREBASE_STORAGE_BUCKET=
VITE_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
VITE_PUBLIC_FIREBASE_APP_ID=
VITE_PUBLIC_FIREBASE_MEASUREMENT_ID=
