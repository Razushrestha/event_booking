# Use a name instead of IP — free hostname setup
# Copy to .env on VPS after you register DuckDNS

# Friendly name (no underscore — DNS does not allow underscores in hostnames)
# Use: eventbooking.duckdns.org  (closest to "event_booking")
APP_HOSTNAME=eventbooking.duckdns.org
APP_DOMAIN=eventbooking.duckdns.org
APP_PORT=3007

# Primary URL to share with users
APP_URL=http://eventbooking.duckdns.org:3007

# Optional clean URL without port (also works if port 80 is open)
# APP_URL=http://eventbooking.duckdns.org

JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-with-openssl-rand-hex-32
JWT_GENERATE=replace-with-openssl-rand-hex-32
ADMIN_BOOTSTRAP_SECRET=replace-with-openssl-rand-hex-24

EMAIL=
PASSWORD=

FIREBASE_PROJECT_ID=
GOOGLE_CLIENT_ID=
VITE_PUBLIC_FIREBASE_API_KEY=
VITE_PUBLIC_FIREBASE_AUTH_DOMAIN=
VITE_PUBLIC_FIREBASE_PROJECT_ID=
VITE_PUBLIC_FIREBASE_STORAGE_BUCKET=
VITE_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
VITE_PUBLIC_FIREBASE_APP_ID=
VITE_PUBLIC_FIREBASE_MEASUREMENT_ID=
