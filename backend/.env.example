WEB_HOST=http://localhost:8000
PORT=8000
NODE_ENV=development

JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret

MONGO_URI=mongodb://localhost:27017/event

EMAIL=your-email@example.com
PASSWORD=your-email-password

FRONTEND_URL=http://localhost:5173
IMAGE_URL=http://localhost:8000

# Optional: required in production for Google sign-in verification
# FIREBASE_PROJECT_ID=your-firebase-project-id
# GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Required only when bootstrapping the first admin account:
# ADMIN_BOOTSTRAP_SECRET=your-bootstrap-secret
